  "keyFeatures": [
    "Deterministic encryption with AES-256-GCM",
    "Envelope format with binary and JSON serialization",
    "Key lifecycle management with rotation support",
    "QAuth identity service with JWT tokens",
    "RBAC with roles and permissions",
    "Multi-factor authentication (TOTP)",
    "Token refresh and revocation",
    "Plugin manifest registration",
    "Stateless in-memory and stateful PostgreSQL storage"
  ],
